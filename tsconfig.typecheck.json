{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "incremental": false,
    "rootDir": ".",
    "paths": {
      "@renx/core": ["./packages/core/src/index.ts"],
      "@renx/toolkit": ["./packages/toolkit/src/index.ts"],
      "@renx/agent": ["./packages/agent/src/index.ts"],
      "@renx/model": ["./packages/model/src/index.ts"],
      "@renx/provider": ["./packages/provider/src/index.ts"],
      "@renx/provider/openai": ["./packages/provider/src/openai/index.ts"],
      "@renx/agent-tools": ["./packages/agent-tools/src/index.ts"],
      "@renx/agent-sandbox": ["./packages/agent-sandbox/src/index.ts"],
      "@renx/coding-agent": ["./packages/coding-agent/src/index.ts"],
      "@renx/cli": ["./packages/cli/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/test/**/*.ts", "vitest.config.ts"]
}
