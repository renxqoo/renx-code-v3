{
  "name": "@renx/agent-tools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild:wasm": "node scripts/ensure-bash-wasm.mjs",
    "build": "pnpm run prebuild:wasm && node ../../scripts/build-package.mjs --external web-tree-sitter",
    "clean": "node ../../scripts/clean-package.mjs"
  },
  "dependencies": {
    "@renx/agent": "workspace:*",
    "ajv": "^8.17.1",
    "shell-quote": "^1.8.1",
    "tree-sitter-bash": "^0.25.1",
    "web-tree-sitter": "^0.26.8",
    "zod": "latest"
  }
}
